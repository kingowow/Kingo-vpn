<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_dark"
    android:fitsSystemWindows="true">

    <!-- Header: Title + Settings -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="KINGO VPN"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-black"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <ImageView
            android:id="@+id/ivSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:importantForAccessibility="no" />

    </LinearLayout>

    <!-- Connection Status + Hint (under title) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_disconnected"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvConnectHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/tap_to_connect"
            android:textColor="@color/text_hint"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Power Button Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center">

            <!-- Outer Glow Ring -->
            <ProgressBar
                android:id="@+id/progressRing"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:indeterminate="false"
                android:indeterminateOnly="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_ring_drawable"
                android:layout_gravity="center"
                android:visibility="gone"
                style="?android:attr/progressBarStyleHorizontal" />

            <!-- Indeterminate Progress Ring -->
            <ProgressBar
                android:id="@+id/progressRingIndeterminate"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:indeterminate="true"
                android:indeterminateDrawable="@drawable/indeterminate_ring"
                android:layout_gravity="center"
                android:visibility="gone" />

            <!-- Power Button -->
            <LinearLayout
                android:id="@+id/btnPower"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:padding="24dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/power_button_bg"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_power"
                    android:layout_gravity="center"
                    android:importantForAccessibility="no" />

            </LinearLayout>

        </FrameLayout>

    </FrameLayout>

    <!-- Timer + Traffic Stats (below power button) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="4dp"
        android:gravity="center">

        <!-- Timer -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textColor="@color/accent"
            android:textSize="22sp"
            android:fontFamily="monospace"
            android:visibility="gone" />

        <!-- Traffic Stats -->
        <LinearLayout
            android:id="@+id/layoutTraffic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvUpload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="↑ 0.0 B/s"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvDownload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↓ 0.0 B/s"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Ping Display (shown when connected) -->
    <LinearLayout
        android:id="@+id/layoutPing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvPingValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/connected"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivRefreshPing"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:padding="3dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_refresh"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:importantForAccessibility="no" />

    </LinearLayout>

    <!-- IP Display (shown when connected) -->
    <LinearLayout
        android:id="@+id/layoutIP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvIP"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Selected Server Name -->
    <TextView
        android:id="@+id/tvSelectedServer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:textColor="@color/accent"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:layout_gravity="center_horizontal"
        android:gravity="center"
        tools:text="Germany VLESS" />

    <!-- Server List Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="12dp"
        android:layout_marginEnd="12dp"
        android:paddingTop="14dp"
        android:orientation="vertical"
        android:background="@drawable/card_background">

        <!-- Server List Header with Three-Dot Menu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/server_list"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Three-dot Menu -->
            <ImageView
                android:id="@+id/ivMenu"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/ic_three_dot_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:importantForAccessibility="no" />

        </LinearLayout>

        <!-- Tab Layout: Favorites / Servers / Custom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/tabFavorites"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tab_favorites"
                android:textColor="@color/tab_unselected"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tabServers"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tab_servers"
                android:textColor="@color/tab_unselected"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tabCustom"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tab_custom"
                android:textColor="@color/tab_unselected"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Get Active Servers Button (shown on Servers tab) -->
        <TextView
            android:id="@+id/btnGetActiveServers"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="@string/get_active_servers"
            android:textColor="@color/primary_dark"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/glass_button_background"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone" />

        <!-- Auto Connect Progress -->
        <LinearLayout
            android:id="@+id/layoutAutoProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvAutoStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_connect_scanning"
                android:textColor="@color/accent"
                android:textSize="12sp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="4dp" />

            <ProgressBar
                android:id="@+id/progressAutoScan"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/custom_progress_bar" />

            <TextView
                android:id="@+id/tvAutoProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_gravity="center_horizontal" />

        </LinearLayout>

        <!-- Server RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvServers"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="2dp"
            android:paddingBottom="8dp"
            android:paddingEnd="2dp"
            android:clipToPadding="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    </LinearLayout>

</LinearLayout>
