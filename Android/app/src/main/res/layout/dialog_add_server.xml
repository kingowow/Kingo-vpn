<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/surface">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Server"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- Subtitle hint -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Paste a vless://, vmess://, trojan:// URI or full v2ray JSON config"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="16dp" />

    <!-- Server Name -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:hint="Server Name (optional)">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etServerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="15sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Config Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:hint="Config (URI or JSON)">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="4"
            android:maxLines="8"
            android:gravity="top"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="13sp"
            android:fontFamily="monospace" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Paste from clipboard button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPaste"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="16dp"
        android:text="📋 Paste from Clipboard"
        android:textColor="@color/accent"
        android:textSize="14sp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    <!-- Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="12dp" />

    <!-- Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Cancel"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdd"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Add Server"
            android:textColor="@color/primary_dark"
            android:backgroundTint="@color/accent"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>
